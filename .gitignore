# Obsidian editor configuration — not repository artifacts
.obsidian/

# Graphify output — tool output, not source content
graphify-out/manifest.json    # mtime-based, breaks after git clone
graphify-out/cost.json        # local only
graphify-out/cache/         # optional: commit for speed, skip to keep repo small

# Stray graphify cache directories in subdirectories (e.g. .claude/graphify-out/)
.claude/graphify-out/
.agents/graphify-out/

